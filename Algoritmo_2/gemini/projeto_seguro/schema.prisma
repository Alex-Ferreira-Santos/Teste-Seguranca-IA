datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    Int     @id @default(autoincrement())
  name  String
  email String  @unique
  role  String  @default("USER")
  password_hash String // Este campo nunca será retornado pelo endpoint acima
}