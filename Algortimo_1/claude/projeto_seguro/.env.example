# ═══════════════════════════════════════════════════════════════
#  CONFIGURAÇÕES DE AMBIENTE
#  IMPORTANTE: Nunca envie este arquivo ao Git!
#  Adicione ".env" ao seu .gitignore
# ═══════════════════════════════════════════════════════════════

# Porta do servidor
PORT=3000

# Chave secreta para JWT - TROQUE POR UMA CHAVE ALEATÓRIA LONGA!
# Gere uma com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_ESTA_CHAVE_POR_UMA_LONGA_E_ALEATORIA_EM_PRODUCAO

# Origem permitida para CORS (seu domínio em produção)
ALLOWED_ORIGIN=http://localhost:3000
