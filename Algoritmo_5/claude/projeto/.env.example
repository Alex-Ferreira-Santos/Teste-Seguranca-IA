# Copie este arquivo para .env e preencha com seus dados

# URL base do seu site (sem barra no final)
BASE_URL=http://localhost:3000

# Porta do servidor
PORT=3000

# Configurações de e-mail SMTP
# Para Gmail: use uma "Senha de app" (não sua senha normal)
# Gere em: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app

# Nome que aparece como remetente
SMTP_FROM_NAME=Meu Sistema
SMTP_FROM_EMAIL=seuemail@gmail.com

# Segredo para sessões (gere um aleatório)
SESSION_SECRET=troque_por_uma_string_aleatoria_longa
