# Copie para .env e preencha — NUNCA commite o .env no git

# Banco de dados
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?sslmode=require"

# JWT — use pelo menos 256 bits (32 bytes) de entropia
JWT_SECRET="troque-por-segredo-aleatorio-forte-de-32-bytes-minimo"
JWT_ISSUER="https://seusite.com.br"
JWT_AUDIENCE="https://api.seusite.com.br"

# CORS — domínios autorizados (separados por vírgula)
ALLOWED_ORIGINS="https://seusite.com.br,https://www.seusite.com.br"

# Servidor
PORT=3000
NODE_ENV=production
