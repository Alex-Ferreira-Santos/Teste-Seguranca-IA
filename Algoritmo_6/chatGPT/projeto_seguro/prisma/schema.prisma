generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FormDraft {
  id          String   @id @default(uuid())
  userId      String   @unique

  formVersion Int

  data        Json

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expiresAt   DateTime?

  @@index([userId])
}